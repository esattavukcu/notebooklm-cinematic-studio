# Buradaki değerleri kendi bilgilerinle doldurup dosya adını .env yap
# Eğer boş bırakırsan ilk çalıştırmada elle login olursun (önerilir).
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# true yaparsan tarayıcı görünmez çalışır (ilk login için false bırak)
HEADLESS=false

# Video üretiminin tamamlanması için max bekleme süresi (dakika)
GENERATION_TIMEOUT_MIN=20
